[Unit]
Description=LLM FineWeb Stage+Shard Watchdog
After=network-online.target
Wants=network-online.target
Conflicts=llm-fineweb-stage-shard-loop.service

[Service]
Type=simple
User=__USER__
WorkingDirectory=__REPO_DIR__
EnvironmentFile=-/etc/llm/llm.env
ExecStart=/bin/bash -lc 'cd __REPO_DIR__ && exec bash scripts/fineweb_stage_shard_watchdog.sh ${LLM_STAGE_SHARD_WATCHDOG_ARGS:-}'
Restart=always
RestartSec=10
KillSignal=SIGINT
TimeoutStopSec=120
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
