[Unit]
Description=LLM Shard Bin Offload To Warm Storage
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=__REPO_DIR__
EnvironmentFile=-%h/.config/llm/llm.env
ExecStart=/bin/bash -lc 'cd __REPO_DIR__ && mkdir -p artifacts/reports && exec flock -n artifacts/reports/shard_offload.lock bash scripts/shard_offload_cycle.sh'
Nice=10
IOSchedulingClass=idle
NoNewPrivileges=true
